{
    "$schema": "https://www.schemastore.org/package.json",
    "name": "tsdoc-config-nick2bad4u",
    "version": "1.0.6",
    "private": false,
    "description": "Shared TSDoc config for Nick2bad4u TypeScript projects.",
    "keywords": [
        "documentation",
        "tsdoc",
        "tsdoc-config",
        "typescript",
        "shared-config"
    ],
    "homepage": "https://github.com/Nick2bad4u/tsdoc-config-nick2bad4u#readme",
    "bugs": {
        "url": "https://github.com/Nick2bad4u/tsdoc-config-nick2bad4u/issues",
        "email": "20943337+Nick2bad4u@users.noreply.github.com"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/Nick2bad4u/tsdoc-config-nick2bad4u.git"
    },
    "license": "MIT",
    "author": "Nick2bad4u <20943337+Nick2bad4u@users.noreply.github.com> (https://github.com/Nick2bad4u)",
    "contributors": [
        {
            "name": "Nick2bad4u",
            "email": "20943337+Nick2bad4u@users.noreply.github.com",
            "url": "https://github.com/Nick2bad4u"
        }
    ],
    "sideEffects": false,
    "type": "module",
    "exports": {
        ".": {
            "types": "./dist/preset.d.ts",
            "import": "./dist/preset.js",
            "require": null
        },
        "./tsdoc.json": "./tsdoc.json",
        "./package.json": "./package.json"
    },
    "main": "./dist/preset.js",
    "types": "./dist/preset.d.ts",
    "files": [
        "dist",
        "tsdoc.json"
    ],
    "scripts": {
        "build": "npm run clean:dist && npx tsc -p tsconfig.build.json",
        "build:runtime": "npm run build",
        "changelog:generate": "git cliff --config node_modules/gitcliff-config-nick2bad4u/cliff.toml --github-repo Nick2bad4u/tsdoc-config-nick2bad4u --output CHANGELOG.md",
        "changelog:preview": "git cliff --config node_modules/gitcliff-config-nick2bad4u/cliff.toml --github-repo Nick2bad4u/tsdoc-config-nick2bad4u --unreleased",
        "changelog:release-notes": "git cliff --config node_modules/gitcliff-config-nick2bad4u/cliff.toml --github-repo Nick2bad4u/tsdoc-config-nick2bad4u --current",
        "clean:dist": "node scripts/clean-dist.mjs",
        "coverage": "npm run build && npx vitest run --coverage",
        "docs:api": "typedoc --options typedoc.json",
        "lint": "npx cross-env NODE_OPTIONS=--max_old_space_size=8192 npx eslint . --cache --cache-strategy content --cache-location .cache/.eslintcache",
        "lint:all": "npm run lint && npm run typecheck && npm run test && npm run lint:remark && npm run lint:prettier && npm run lint:package && npm run lint:yaml && npm run lint:yamllint && npm run lint:gitleaks && npm run lint:secretlint",
        "lint:all:fix": "npm run lint:fix && npm run lint:remark:fix && npm run lint:prettier:fix && npm run lint:package:fix && npm run typecheck && npm run test && npm run lint:yaml:fix && npm run lint:secretlint",
        "lint:attw": "npx attw --pack . --profile esm-only",
        "lint:fix": "npm run lint -- --fix",
        "lint:gitleaks": "gitleaks dir --config .gitleaks.toml .",
        "lint:jscpd": "jscpd --config node_modules/jscpd-config-nick2bad4u/jscpd.json",
        "lint:lychee": "lychee --config node_modules/lychee-config-nick2bad4u/lychee.toml .",
        "lint:lychee:smoke": "lychee --config node_modules/lychee-config-nick2bad4u/lychee.toml --dump-inputs README.md",
        "lint:package": "npm run lint:package-sort && npm run lint:package-json && npm run lint:package-check",
        "lint:package:fix": "npx sort-package-json package.json",
        "lint:package-check": "npm run package:check && npm run lint:publint && npm run lint:attw",
        "lint:package-fix": "npm run lint:package:fix",
        "lint:package-json": "npmPkgJsonLint . --config .npmpackagejsonlintrc.json",
        "lint:package-sort": "npx sort-package-json --check package.json",
        "lint:prettier": "npx prettier . --log-level warn --cache --cache-location=.cache/.prettier-cache --cache-strategy=content --check",
        "lint:prettier:fix": "npx prettier . --log-level warn --cache --cache-location=.cache/.prettier-cache --cache-strategy=content --write",
        "lint:publint": "npx publint",
        "lint:remark": "remark . --frail --ignore-path .remarkignore",
        "lint:remark:fix": "remark . --ignore-path .remarkignore --output",
        "lint:secretlint": "npx secretlint --secretlintrc .secretlintrc.cjs --secretlintignore .gitignore \"**/*\"",
        "lint:yaml": "npx eslint --cache --cache-strategy content --cache-location .cache/.eslintcache \"**/*.{yml,yaml}\"",
        "lint:yaml:fix": "npm run lint:yaml -- --fix",
        "lint:yamllint": "yamllint -c .yamllint .",
        "package:check": "npm pack --dry-run",
        "release:check": "npm run release:verify",
        "release:verify": "npm run build && npm run lint:all && npm run lint:package-check",
        "sync:node-version-files": "node scripts/sync-node-version-files.mjs",
        "test": "npm run build && npx vitest run",
        "test:coverage": "npm run coverage",
        "typecheck": "npm run build && npx tsc -p tsconfig.json --noEmit && npx tsc -p tsconfig.eslint.json --noEmit && npx tsc -p tsconfig.js.json --noEmit && npx tsc -p tsconfig.vitest-typecheck.json --noEmit",
        "typecheck:all": "npm run typecheck",
        "types:update": "npx typesync",
        "update-actions": "npx actions-up --yes --style sha",
        "update-deps": "ncu --configFileName .ncurc.json --configFilePath node_modules/ncu-config-nick2bad4u && npm update --force && npm install --force && npm run sync:node-version-files",
        "verify": "npm run release:verify"
    },
    "dependencies": {
        "typedoc": "^0.28.20"
    },
    "devDependencies": {
        "@arethetypeswrong/cli": "^0.18.5",
        "@microsoft/tsdoc": "^0.16.0",
        "@microsoft/tsdoc-config": "^0.18.1",
        "@types/node": "^26.1.1",
        "@vitest/coverage-v8": "^4.1.10",
        "cross-env": "^10.1.0",
        "eslint": "^10.7.0",
        "eslint-config-nick2bad4u": "^5.0.0",
        "git-cliff": "^2.13.1",
        "gitcliff-config-nick2bad4u": "^1.3.0",
        "gitleaks-config-nick2bad4u": "^1.0.4",
        "jscpd": "^5.0.12",
        "jscpd-config-nick2bad4u": "^1.1.0",
        "lychee-config-nick2bad4u": "^2.0.0",
        "ncu-config-nick2bad4u": "^0.2.0",
        "npm-check-updates": "^22.2.9",
        "npm-package-json-lint": "^10.4.1",
        "npm-package-json-lint-config-nick2bad4u": "^1.0.4",
        "picocolors": "^1.1.1",
        "prettier": "^3.9.5",
        "prettier-config-nick2bad4u": "^1.1.1",
        "publint": "^0.3.21",
        "remark": "^15.0.1",
        "remark-cli": "^12.0.1",
        "remark-config-nick2bad4u": "^1.1.3",
        "secretlint": "^13.0.2",
        "secretlint-config-nick2bad4u": "^1.1.2",
        "sort-package-json": "^4.0.0",
        "typedoc-config-nick2bad4u": "^2.0.3",
        "typescript": "^6.0.3",
        "vite": "^8.1.4",
        "vitest": "^4.1.10",
        "yamllint-config-nick2bad4u": "^1.1.1"
    },
    "peerDependencies": {
        "@microsoft/tsdoc-config": ">=0.18.0"
    },
    "packageManager": "npm@12.0.1",
    "engines": {
        "node": ">=22.0.0"
    },
    "devEngines": {
        "runtime": {
            "name": "node",
            "version": ">=22.0.0",
            "onFail": "error"
        },
        "packageManager": {
            "name": "npm",
            "version": ">=11.0.0",
            "onFail": "error"
        }
    },
    "publishConfig": {
        "provenance": true,
        "registry": "https://registry.npmjs.org/"
    },
    "readme": "README.md"
}
