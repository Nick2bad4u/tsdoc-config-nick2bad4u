{
    "$schema": "https://developer.microsoft.com/json-schemas/tsdoc/v0/tsdoc.schema.json",
    "extends": [
        "typedoc/tsdoc.json"
    ],
    "supportForTags": {
        "@alpha": true,
        "@beta": true,
        "@decorator": true,
        "@defaultValue": true,
        "@deprecated": true,
        "@eventProperty": true,
        "@example": true,
        "@experimental": true,
        "@inheritDoc": true,
        "@internal": true,
        "@jsx": true,
        "@jsxFrag": true,
        "@jsxImportSource": true,
        "@jsxRuntime": true,
        "@label": true,
        "@link": true,
        "@override": true,
        "@packageDocumentation": true,
        "@param": true,
        "@privateRemarks": true,
        "@public": true,
        "@readonly": true,
        "@remarks": true,
        "@returns": true,
        "@sealed": true,
        "@see": true,
        "@throws": true,
        "@typeParam": true,
        "@virtual": true
    }
}
